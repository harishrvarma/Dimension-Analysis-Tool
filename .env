# App settings
APP_NAME=my_app
APP_ENV=development
DEBUG=true
SECRET_KEY=super-secret-key-change-me

# Database
DATABASE_URL=mysql+pymysql://user:password@host:port/databasename

# Redis / cache
#REDIS_URL=redis://localhost:6379/0

# API keys
